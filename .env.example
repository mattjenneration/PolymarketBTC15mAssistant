# =============================================================================
# Polymarket BTC assistant — environment template
# Copy: cp .env.example .env   then fill secrets. Never commit .env.
# Dashboard reads the same vars when you run the bot; PM2 loads .env if configured.
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets (live trading)
# -----------------------------------------------------------------------------
# Wallet private key for signing CLOB orders (0x… hex). Required when ENABLE_LIVE_TRADING=true.
PRIVATE_KEY=0x6fa817e701b793abb33893b863bcf7d6ec608baf241ebc370618d4c969910811

# Polymarket proxy / smart wallet that holds USDC (your Polymarket “funder” address).
# Same value can use either name.
POLYMARKET_FUNDER_ADDRESS=0x13E7bfd73ac7e12888d73C558e795A2CD8382765
# POLY_FUNDER_ADDRESS=

# CLOB signature type: 0=EOA, 1=POLY_PROXY, 2=GNOSIS_SAFE (typical for Polymarket UI wallets).
POLY_SIGNATURE_TYPE=2

# -----------------------------------------------------------------------------
# Live trading master switch & sizing
# -----------------------------------------------------------------------------
# true = place real USDC orders (still subject to guards below).
ENABLE_LIVE_TRADING=false

# Minimum |confidence score| (0–100) to consider a live bid. DOWN adds DOWN_SIDE_EXTRA_THRESHOLD.
TRADE_THRESHOLD=75

# USDC notional per order attempt.
POSITION_SIZE_USD=1

# Minutes after any live order attempt (ok or error) before another attempt.
COOLDOWN_MINUTES=15

# Fire only when remaining time in the window is at most this many seconds (e.g. last ~1–3 min of 5m).
TRADE_TIMING_SECONDS=65

# Optional extra logging around the relayer/CLOB path.
DEBUG_LIVE_TRADING=false

# -----------------------------------------------------------------------------
# Order type & execution
# -----------------------------------------------------------------------------
# FAK = fill available then cancel remainder; FOK = all or nothing.
MARKET_ORDER_TYPE=FAK

# Worst-price limit = bestAsk * (1 + this). E.g. 0.03 = 3% above touch.
MARKET_ORDER_SLIPPAGE_PCT=0.03

# Fallback cap if CONFIDENCE_MAX_BID_LADDER is empty (price per share 0.01–0.99).
MAX_BID_PRICE=0.95

# Ladder: "threshold:maxPrice,…" using absolute confidence 0–100. Highest threshold ≤ |score| wins.
# Example: low confidence → only buy very cheap shares; high confidence → allow higher ask.
# CONFIDENCE_MAX_BID_LADDER=0:0.15,20:0.35,40:0.6,60:0.7,80:0.75

# USDC on Polygon (default Polymarket bridged USDC).
# USDC_ADDRESS=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174

# -----------------------------------------------------------------------------
# Model confidence (TA + futures / microstructure)
# -----------------------------------------------------------------------------
# How much futures + OB micro scores (-100..100) blend into TA: final ≈ TA + weight * aux.
CONFIDENCE_AUXILIARY_WEIGHT=0.22

# -----------------------------------------------------------------------------
# Live bid guards (informed bidding — avoid coin-flip entries)
# -----------------------------------------------------------------------------
# Require edge engine ENTER on the same side as confidence (see src/engines/edge.js).
# false = legacy behavior (confidence only); not recommended.
REQUIRE_EDGE_ENGINE_ENTER=true

# Minimum (model_prob − market_prob) on the traded side before a live bid (0–0.5). Higher = fewer, pickier trades.
LIVE_MIN_MODEL_EDGE=0.10

# Skip bids when best ask is in this probability band (market ~50/50). Prices are 0–1 per share.
COIN_FLIP_MIN_PRICE=0.42
COIN_FLIP_MAX_PRICE=0.58
ENFORCE_COIN_FLIP_GUARD=true

# Extra points of |confidence| required for DOWN vs UP (DOWN often weaker in logs).
DOWN_SIDE_EXTRA_THRESHOLD=12

# Chop: mean |Δconfidence| over CHOP_WINDOW_MS; above this → skip (whipsaw).
MAX_CONFIDENCE_SWING_MEAN_ABS=22
CHOP_WINDOW_MS=30000
ENFORCE_CHOP_GUARD=true

# -----------------------------------------------------------------------------
# Circuit breaker (after settled markets with live fills)
# -----------------------------------------------------------------------------
CIRCUIT_BREAKER_ENABLED=true
# Rolling count of recent made-trade outcomes (WIN/LOSS) kept in memory.
CIRCUIT_BREAKER_WINDOW=8
# Need at least this many outcomes before breaker can trip.
CIRCUIT_BREAKER_MIN_TRADES=6
# If win rate in the window falls below this, pause new bids.
CIRCUIT_BREAKER_MIN_WIN_RATE=0.45
# How long to pause (minutes) after a trip.
CIRCUIT_BREAKER_PAUSE_MINUTES=45

# -----------------------------------------------------------------------------
# Polymarket market selection
# -----------------------------------------------------------------------------
# Leave empty to auto-pick latest from series (POLYMARKET_AUTO_SELECT_LATEST=true).
POLYMARKET_SLUG=

POLYMARKET_SERIES_ID=10684
POLYMARKET_SERIES_SLUG=btc-up-or-down-5m
POLYMARKET_AUTO_SELECT_LATEST=true

POLYMARKET_LIVE_WS_URL=wss://ws-live-data.polymarket.com
POLYMARKET_UP_LABEL=Up
POLYMARKET_DOWN_LABEL=Down

# -----------------------------------------------------------------------------
# Polygon / Chainlink (spot reference & RPC)
# -----------------------------------------------------------------------------
# Comma-separated fallbacks optional.
# POLYGON_RPC_URLS=https://polygon-rpc.com,https://rpc.ankr.com/polygon
POLYGON_RPC_URL=https://rpc.ankr.com/polygon
# POLYGON_WSS_URL=
# POLYGON_WSS_URLS=

# Chainlink BTC/USD aggregator on Polygon (default is common deployment).
# CHAINLINK_BTC_USD_AGGREGATOR=0xc907E116054Ad103354f2D350FD2514433D57F6f

# -----------------------------------------------------------------------------
# Simulation (no private key)
# -----------------------------------------------------------------------------
BUDGET_USD=0
BET_AMOUNT_USD=0

# -----------------------------------------------------------------------------
# Bot timeframe label (informational / future use)
# BOT_TIMEFRAME=5m

# -----------------------------------------------------------------------------
# Prediction outcome logging (seconds before end to snapshot side)
# PREDICTION_TIMINGS_SECONDS=120,90,60

# -----------------------------------------------------------------------------
# Logging & console
# -----------------------------------------------------------------------------
# Min milliseconds between signals.csv + gpt_indicators.csv rows; 0 = every poll.
# Always logs the tick when a live arm would fire.
LOG_SIGNALS_THROTTLE_MS=30000

# Fewer TUI lines (keeps market, confidence, live arm, Polymarket block).
QUIET_CONSOLE=false

# -----------------------------------------------------------------------------
# Dashboard HTTP server (src/server.js)
# -----------------------------------------------------------------------------
DASHBOARD_PORT=3000
# Optional: if set, POST /api/manual-bid requires this value as JSON body "secret" or Authorization: Bearer …
# DASHBOARD_MANUAL_BID_SECRET=

# -----------------------------------------------------------------------------
# HTTP proxy (optional — undici global dispatcher + WS agents)
# -----------------------------------------------------------------------------
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
# ALL_PROXY=socks5://127.0.0.1:1080
